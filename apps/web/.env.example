# Supabase project URL from the Dashboard Connect dialog.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key for browser and server SSR clients.
# Do not use a secret key or service-role key here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_project_publishable_key

# Trusted application origin used for Supabase email redirects.
# Use http only for localhost or 127.0.0.1.
APP_ORIGIN=http://localhost:3000

# Server-only FastAPI AI service integration.
# Generate one random secret of at least 32 characters and configure the same value on both services.
# Do not prefix these with NEXT_PUBLIC_ and do not commit the real token.
AI_SERVICE_URL=http://127.0.0.1:8000
AI_INTERNAL_API_TOKEN=
AI_REQUEST_TIMEOUT_MS=120000
