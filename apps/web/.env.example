# Supabase project URL from the Dashboard Connect dialog.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key for browser and server SSR clients.
# Do not use a secret key or service-role key here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_project_publishable_key

# Trusted application origin used for Supabase email redirects.
# Use http only for localhost or 127.0.0.1.
APP_ORIGIN=http://localhost:3000
